<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="start"
            android:background="@drawable/bg_back_button"
            android:contentDescription="Back"
            android:padding="9dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:tint="@android:color/holo_blue_dark" />

        <TextView
            android:id="@+id/txtWorldTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="World Title"
            android:textColor="@color/cq_text"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtWorldSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complete each level to unlock the next one."
            android:textColor="@color/cq_muted"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- LEVEL 1 -->
        <LinearLayout
            android:id="@+id/cardLevel1"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_unlocked"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:id="@+id/txtLevel1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level 1"
                android:textColor="@color/cq_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/starsLevel1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- LEVEL 2 -->
        <LinearLayout
            android:id="@+id/cardLevel2"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_locked"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:id="@+id/txtLevel2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level 2"
                android:textColor="@color/cq_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/starsLevel2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- LEVEL 3 -->
        <LinearLayout
            android:id="@+id/cardLevel3"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_locked"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:id="@+id/txtLevel3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level 3"
                android:textColor="@color/cq_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/starsLevel3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- LEVEL 4 -->
        <LinearLayout
            android:id="@+id/cardLevel4"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_locked"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:id="@+id/txtLevel4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level 4"
                android:textColor="@color/cq_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/starsLevel4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- LEVEL 5 -->
        <LinearLayout
            android:id="@+id/cardLevel5"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/card_locked"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:id="@+id/txtLevel5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Level 5"
                android:textColor="@color/cq_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/starsLevel5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>