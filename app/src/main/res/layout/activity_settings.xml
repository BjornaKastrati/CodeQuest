<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_back_button"
        android:contentDescription="Back"
        android:padding="9dp"
        android:src="@drawable/baseline_arrow_back_24"
        android:tint="@android:color/holo_blue_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtSettingsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="@color/cq_text"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/cardSettings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <LinearLayout
        android:id="@+id/cardSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_unlocked"
        android:padding="20dp"
        android:layout_marginTop="36dp"
        app:layout_constraintBottom_toTopOf="@id/btnBackHome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtSettingsTitle">

        <Switch
            android:id="@+id/switchSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sound Effects"
            android:textColor="@color/cq_text"
            android:textSize="18sp"
            android:checked="true" />

        <Switch
            android:id="@+id/switchAnimations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Animations"
            android:textColor="@color/cq_text"
            android:textSize="18sp"
            android:checked="true"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/txtSettingsNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress is saved using SharedPreferences."
            android:textColor="@color/cq_muted"
            android:textSize="14sp"
            android:layout_marginTop="22dp" />

        <Button
            android:id="@+id/btnResetProgress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/btn_secondary"
            android:text="Reset Progress"
            android:textAllCaps="false"
            android:textColor="@color/cq_text"
            android:textSize="17sp"
            android:layout_marginTop="24dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnBackHome"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:background="@drawable/btn_primary"
        android:text="Back Home"
        android:textAllCaps="false"
        android:textColor="#03111F"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="34dp"
        app:layout_constraintTop_toBottomOf="@id/cardSettings"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>