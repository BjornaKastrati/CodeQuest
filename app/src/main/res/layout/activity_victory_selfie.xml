<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="22dp">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_back_button"
        android:contentDescription="Back"
        android:padding="9dp"
        android:src="@drawable/baseline_arrow_back_24"
        android:tint="@android:color/holo_blue_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.codequest.views.ConfettiView
        android:id="@+id/confettiView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtVictoryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="VICTORY ACHIEVED 👑"
        android:textColor="@color/cq_text"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/photoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <FrameLayout
        android:id="@+id/photoContainer"
        android:layout_width="290dp"
        android:layout_height="340dp"
        android:layout_marginTop="26dp"
        android:background="@drawable/card_unlocked"
        app:layout_constraintTop_toBottomOf="@id/txtVictoryHeader"
        app:layout_constraintBottom_toTopOf="@id/txtVictoryMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgSelfie"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Victory selfie" />

        <TextView
            android:id="@+id/txtPhotoPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="📸\nWaiting for selfie..."
            android:textColor="@color/cq_muted"
            android:textSize="23sp"
            android:gravity="center" />

        <ImageView
            android:id="@+id/imgCrown"
            android:layout_width="150dp"
            android:layout_height="140dp"
            android:layout_gravity="top|center_horizontal"
            android:translationY="-25dp"
            android:src="@drawable/crown"
            android:contentDescription="Victory crown" />

    </FrameLayout>

    <TextView
        android:id="@+id/txtVictoryMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Victory message"
        android:textColor="@color/cq_accent"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="26dp"
        app:layout_constraintTop_toBottomOf="@id/photoContainer"
        app:layout_constraintBottom_toTopOf="@id/btnContinueVictory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnContinueVictory"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:background="@drawable/btn_primary"
        android:text="Continue"
        android:textAllCaps="false"
        android:textColor="#03111F"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/txtVictoryMessage"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>